<UserControl
    x:Class="SlackSitter.Views.StatusPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel
        x:Name="RootPanel"
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Spacing="16"
        MaxWidth="700"
        Visibility="Visible">
        <TextBlock
            x:Name="StatusText"
            Text=""
            FontSize="14"
            HorizontalAlignment="Center"
            TextWrapping="Wrap"
            TextAlignment="Center"
            Foreground="Green" />

        <TextBlock
            x:Name="ErrorText"
            Text=""
            FontSize="14"
            HorizontalAlignment="Center"
            TextWrapping="Wrap"
            TextAlignment="Center"
            Foreground="Red"
            Visibility="Collapsed" />

        <Border
            x:Name="RequiredScopesPanel"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
            BorderThickness="2"
            CornerRadius="8"
            Padding="16"
            Visibility="Collapsed">
            <StackPanel Spacing="8">
                <TextBlock
                    Text="⚠️ 必要な権限（スコープ）"
                    FontWeight="Bold"
                    FontSize="16" />
                <TextBlock
                    Text="Access Token に以下の権限が必要です："
                    TextWrapping="Wrap" />
                <TextBlock
                    Text="• channels:read - パブリックチャンネルの読み取り"
                    FontFamily="Consolas" />
                <TextBlock
                    Text="• channels:history - パブリックチャンネルのメッセージ履歴"
                    FontFamily="Consolas" />
                <TextBlock
                    Text="• groups:read - プライベートチャンネルの読み取り"
                    FontFamily="Consolas" />
                <TextBlock
                    Text="• groups:history - プライベートチャンネルのメッセージ履歴"
                    FontFamily="Consolas" />
                <TextBlock
                    Text="• mpim:read - グループDMの読み取り"
                    FontFamily="Consolas" />
                <TextBlock
                    Text="• mpim:history - グループDMのメッセージ履歴"
                    FontFamily="Consolas" />
                <TextBlock
                    Text="• im:read - DMの読み取り"
                    FontFamily="Consolas" />
                <TextBlock
                    Text="• im:history - DMのメッセージ履歴"
                    FontFamily="Consolas" />
                <TextBlock
                    Text="• users:read - ユーザー情報の読み取り"
                    FontFamily="Consolas" />
                <TextBlock
                    Text="• chat:write - メッセージの送信"
                    FontFamily="Consolas" />
                <TextBlock
                    Text="• emoji:read - カスタム絵文字の読み取り"
                    FontFamily="Consolas" />
                <TextBlock Text="" />
                <TextBlock
                    Text="Slack App の設定で OAuth Scopes にこれらの権限を追加し、新しいトークンを再発行してください。"
                    TextWrapping="Wrap"
                    Foreground="Gray" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
