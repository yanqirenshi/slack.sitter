<UserControl
    x:Class="SlackSitter.Views.PopupBubbleView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Border
            Background="{Binding BubbleBackground, ElementName=Root}"
            BorderBrush="{Binding BubbleBorderBrush, ElementName=Root}"
            BorderThickness="{Binding BubbleBorderThickness, ElementName=Root}"
            CornerRadius="{Binding BubbleCornerRadius, ElementName=Root}"
            Padding="{Binding BubblePadding, ElementName=Root}"
            MinWidth="{Binding BubbleMinWidth, ElementName=Root}"
            MaxWidth="{Binding BubbleMaxWidth, ElementName=Root}"
            Margin="0,0,0,15">
            <ContentPresenter Content="{Binding PopupContent, ElementName=Root}" />
        </Border>

        <Polygon
            Points="0,0 10,15 20,0"
            Fill="{Binding BubbleBackground, ElementName=Root}"
            Stroke="{Binding BubbleBorderBrush, ElementName=Root}"
            StrokeThickness="{Binding PointerStrokeThickness, ElementName=Root}"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,0" />
    </Grid>
</UserControl>
