<UserControl
    x:Class="SlackSitter.Views.LogPopupView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <Grid>
        <Border
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16"
            MinWidth="400"
            MaxWidth="600"
            Margin="0,0,0,15">
            <StackPanel Spacing="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock
                        Grid.Column="0"
                        Text="&#x30C7;&#x30FC;&#x30BF;&#x53D6;&#x5F97;&#x30ED;&#x30B0;"
                        FontWeight="SemiBold"
                        FontSize="14"
                        VerticalAlignment="Center" />
                    <Button
                        Grid.Column="1"
                        Content="&#x30ED;&#x30B0;&#x3092;&#x3059;&#x3079;&#x3066;&#x30B3;&#x30D4;&#x30FC;"
                        Click="CopyLogButton_Click"
                        Padding="10,4"
                        HorizontalAlignment="Right" />
                </Grid>
                <Border
                    Height="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                <ScrollViewer
                    MaxHeight="300"
                    VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="LogItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock
                                    Text="{Binding}"
                                    FontSize="11"
                                    FontFamily="Consolas"
                                    TextWrapping="Wrap"
                                    Margin="0,2" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <Button
                    x:Name="RefreshDataButton"
                    Content="&#x518D;&#x53D6;&#x5F97;"
                    Click="RefreshDataButton_Click"
                    HorizontalAlignment="Right"
                    Padding="10,4" />
            </StackPanel>
        </Border>
        <Polygon
            Points="0,0 10,15 20,0"
            Fill="{ThemeResource LayerFillColorDefaultBrush}"
            Stroke="{ThemeResource CardStrokeColorDefaultBrush}"
            StrokeThickness="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,0" />
    </Grid>
</UserControl>
