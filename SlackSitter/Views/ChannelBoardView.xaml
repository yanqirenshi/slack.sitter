<UserControl
    x:Class="SlackSitter.Views.ChannelBoardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:SlackSitter.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <DataTemplate x:Key="ChannelCardTemplate">
            <views:ChannelCardView
                Channel="{Binding}"
                ImagePreviewRequested="ChannelCardView_ImagePreviewRequested"
                ReactionRequested="ChannelCardView_ReactionRequested"
                ShowImageRequested="ChannelCardView_ShowImageRequested" />
        </DataTemplate>
    </UserControl.Resources>

    <ScrollViewer
        x:Name="ChannelScrollViewer"
        HorizontalScrollBarVisibility="Auto"
        VerticalScrollBarVisibility="Disabled"
        Padding="20"
        SizeChanged="ChannelScrollViewer_SizeChanged">
        <ItemsRepeater
            x:Name="TimesChannelsItemsRepeater"
            ItemTemplate="{StaticResource ChannelCardTemplate}">
            <ItemsRepeater.Layout>
                <views:HorizontalVirtualizingLayout Spacing="16" EstimatedItemWidth="356" />
            </ItemsRepeater.Layout>
        </ItemsRepeater>
    </ScrollViewer>
</UserControl>
