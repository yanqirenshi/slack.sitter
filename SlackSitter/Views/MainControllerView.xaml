<UserControl
    x:Class="SlackSitter.Views.MainControllerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:SlackSitter.Views"
    mc:Ignorable="d">

    <Grid x:Name="RootGrid">
        <views:PopupBubbleView
            x:Name="GearPopupBorder"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Visibility="Collapsed"
            BubbleBackground="{ThemeResource OpaquePopupBackgroundBrush}"
            BubbleBorderBrush="{ThemeResource OpaquePopupBorderBrush}"
            BubbleWidth="700"
            BubbleHeight="500">
            <views:PopupBubbleView.PopupContent>
                <Grid ColumnSpacing="20" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox
                        x:Name="GearChannelNameTextBox"
                        Grid.Row="0"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        PlaceholderText="名称"
                        TextChanged="GearChannelNameTextBox_TextChanged" />

                    <TextBox
                        x:Name="GearChannelFilterTextBox"
                        Grid.Row="1"
                        Grid.Column="0"
                        PlaceholderText="チャンネル名で絞り込み"
                        TextChanged="PlusChannelFilterTextBox_TextChanged" />

                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        Text="対象チャンネル"
                        FontWeight="SemiBold"
                        FontSize="24"
                        VerticalAlignment="Center" />

                    <ListView
                        x:Name="GearAvailableChannelsListView"
                        Grid.Row="2"
                        Grid.Column="0"
                        ItemsSource="{x:Bind FilteredAvailableChannels}"
                        IsItemClickEnabled="False"
                        DoubleTapped="AvailableChannelsListView_DoubleTapped"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{x:Bind}" TextWrapping="WrapWholeWords" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <ListView
                        x:Name="GearSelectedChannelsListView"
                        Grid.Row="2"
                        Grid.Column="1"
                        ItemsSource="{x:Bind SelectedChannels}"
                        DoubleTapped="SelectedChannelsListView_DoubleTapped"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{x:Bind}" TextWrapping="WrapWholeWords" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button
                        Grid.Row="3"
                        Grid.Column="0"
                        Content="Cancel"
                        HorizontalAlignment="Left"
                        Padding="16,8"
                        Click="GearCancelButton_Click" />

                    <Button
                        x:Name="GearUpdateChannelsButton"
                        Grid.Row="3"
                        Grid.Column="1"
                        Content="変更"
                        HorizontalAlignment="Right"
                        Padding="16,8"
                        IsEnabled="False"
                        Click="GearUpdateChannelsButton_Click" />
                </Grid>
            </views:PopupBubbleView.PopupContent>
        </views:PopupBubbleView>

        <views:PopupBubbleView
            x:Name="PlusPopupBorder"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Visibility="Collapsed"
            BubbleBackground="{ThemeResource OpaquePopupBackgroundBrush}"
            BubbleBorderBrush="{ThemeResource OpaquePopupBorderBrush}"
            BubbleWidth="700"
            BubbleHeight="500">
            <views:PopupBubbleView.PopupContent>
                <Grid ColumnSpacing="20" RowSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox
                        x:Name="PlusChannelNameTextBox"
                        Grid.Row="0"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        PlaceholderText="名称" />

                    <TextBox
                        x:Name="PlusChannelFilterTextBox"
                        Grid.Row="1"
                        Grid.Column="0"
                        PlaceholderText="チャンネル名で絞り込み"
                        TextChanged="PlusChannelFilterTextBox_TextChanged" />

                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="1"
                        Text="対象チャンネル"
                        FontWeight="SemiBold"
                        FontSize="24"
                        VerticalAlignment="Center" />

                    <ListView
                        x:Name="AvailableChannelsListView"
                        Grid.Row="2"
                        Grid.Column="0"
                        ItemsSource="{x:Bind FilteredAvailableChannels}"
                        IsItemClickEnabled="False"
                        DoubleTapped="AvailableChannelsListView_DoubleTapped"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{x:Bind}" TextWrapping="WrapWholeWords" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <ListView
                        x:Name="SelectedChannelsListView"
                        Grid.Row="2"
                        Grid.Column="1"
                        ItemsSource="{x:Bind SelectedChannels}"
                        DoubleTapped="SelectedChannelsListView_DoubleTapped"
                        SelectionMode="Single">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <TextBlock Text="{x:Bind}" TextWrapping="WrapWholeWords" />
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <Button
                        Grid.Row="3"
                        Grid.Column="0"
                        Content="Cancel"
                        HorizontalAlignment="Left"
                        Padding="16,8"
                        Click="PlusCancelButton_Click" />

                    <Button
                        x:Name="AddChannelsButton"
                        Grid.Row="3"
                        Grid.Column="1"
                        Content="追加"
                        HorizontalAlignment="Right"
                        Padding="16,8"
                        Click="AddChannelsButton_Click" />
                </Grid>
            </views:PopupBubbleView.PopupContent>
        </views:PopupBubbleView>

        <views:UserPopupView
            x:Name="UserPopupBorder"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Visibility="Collapsed" />

        <views:LogPopupView
            x:Name="ActivityLogPopupBorder"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Visibility="Collapsed" />

        <views:CircleActionButtonView
            x:Name="LogIconButton"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="-236,0,0,20"
            InnerBorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
            CenterGlyph="&#xEA37;"
            Click="LogIconButton_Click"
            Visibility="Collapsed" />

        <views:CircleActionButtonView
            x:Name="LoadingIndicatorButton"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="236,0,0,20"
            CenterGlyph="&#xE895;"
            ContentForeground="Gray"
            IsCircular="False"
            Click="LoadingIndicatorButton_Click"
            Visibility="Collapsed" />

        <views:CircleActionButtonView
            x:Name="UserAvatarButton"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="-118,0,0,20"
            InnerBorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
            Click="UserAvatarButton_Click"
            Visibility="Collapsed" />

        <views:CircleActionButtonView
            x:Name="GearIconButton"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="0,0,0,20"
            InnerBorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
            CenterGlyph="&#xE713;"
            Click="GearIconButton_Click"
            Visibility="Collapsed" />

        <views:CircleActionButtonView
            x:Name="PlusIconButton"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="118,0,0,20"
            InnerBorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
            CenterGlyph="&#xE710;"
            Click="PlusIconButton_Click"
            Visibility="Collapsed" />

        <views:CircleActionButtonView
            x:Name="CircleIcon1Button"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="354,0,0,20"
            IsCircular="False"
            InnerBorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
            CenterText="①"
            Click="CircleIcon1Button_Click"
            Visibility="Collapsed" />

        <views:CircleActionButtonView
            x:Name="CircleIcon2Button"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            Margin="472,0,0,20"
            IsCircular="False"
            InnerBorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
            CenterText="②"
            Click="CircleIcon2Button_Click"
            Visibility="Collapsed" />

        <Grid x:Name="CustomChannelButtonsHost" />
    </Grid>
</UserControl>