<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SlackSitter.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SlackSitter"
    xmlns:converters="using:SlackSitter.Converters"
    xmlns:views="using:SlackSitter.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SlackSitter">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <converters:TimestampToDateTimeConverter x:Key="TimestampToDateTimeConverter" />
            <converters:BooleanToHeaderBrushConverter x:Key="BooleanToHeaderBrushConverter" />
            <converters:SlackMessageTextConverter x:Key="SlackMessageTextConverter" />
        </Grid.Resources>
        <views:AuthenticationView
            x:Name="AuthenticationPanel"
            Visibility="Collapsed"
            AuthenticateRequested="AuthenticationView_AuthenticateRequested" />

        <Grid x:Name="MainPanel" Visibility="Collapsed">
            <views:ChannelBoardView
                x:Name="AllChannelBoard"
                Visibility="Collapsed"
                MessageRichTextBlockLoadedRequested="ChannelCardView_MessageRichTextBlockLoadedRequested"
                MessageAvatarBorderLoadedRequested="ChannelCardView_MessageAvatarBorderLoadedRequested"
                ReactionBorderLoadedRequested="ChannelCardView_ReactionBorderLoadedRequested"
                ShowImageRequested="ChannelCardView_ShowImageRequested" />

            <views:ChannelBoardView
                x:Name="JoinedChannelBoard"
                Visibility="Visible"
                MessageRichTextBlockLoadedRequested="ChannelCardView_MessageRichTextBlockLoadedRequested"
                MessageAvatarBorderLoadedRequested="ChannelCardView_MessageAvatarBorderLoadedRequested"
                ReactionBorderLoadedRequested="ChannelCardView_ReactionBorderLoadedRequested"
                ShowImageRequested="ChannelCardView_ShowImageRequested" />

            <views:ChannelBoardView
                x:Name="NotJoinedChannelBoard"
                Visibility="Collapsed"
                MessageRichTextBlockLoadedRequested="ChannelCardView_MessageRichTextBlockLoadedRequested"
                MessageAvatarBorderLoadedRequested="ChannelCardView_MessageAvatarBorderLoadedRequested"
                ReactionBorderLoadedRequested="ChannelCardView_ReactionBorderLoadedRequested"
                ShowImageRequested="ChannelCardView_ShowImageRequested" />

            <views:StatusPanelView x:Name="StatusPanel" />

            <views:MainControllerView
                x:Name="MainController"
                GearIconClick="MainController_GearIconClick"
                PlusIconClick="MainController_PlusIconClick"
                CircleIcon1Click="MainController_CircleIcon1Click"
                CircleIcon2Click="MainController_CircleIcon2Click"
                CopyLogRequested="LogPopupView_CopyLogRequested"
                RefreshRequested="LogPopupView_RefreshRequested"
                UpdateTokenRequested="UserPopupView_UpdateTokenRequested"
                LogoutRequested="UserPopupView_LogoutRequested"
                AutoRefreshToggleRequested="UserPopupView_AutoRefreshToggleRequested" />
        </Grid>
    </Grid>
</Window>
