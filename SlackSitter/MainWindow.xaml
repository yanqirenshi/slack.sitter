<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SlackSitter.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SlackSitter"
    xmlns:converters="using:SlackSitter.Converters"
    xmlns:views="using:SlackSitter.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SlackSitter">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <converters:TimestampToDateTimeConverter x:Key="TimestampToDateTimeConverter" />
            <converters:BooleanToHeaderBrushConverter x:Key="BooleanToHeaderBrushConverter" />
            <converters:SlackMessageTextConverter x:Key="SlackMessageTextConverter" />
        </Grid.Resources>

        <views:AuthenticationView
            x:Name="AuthenticationPanel"
            Visibility="Collapsed"
            AuthenticateRequested="AuthenticationView_AuthenticateRequested" />

        <Grid x:Name="MainPanel" Visibility="Collapsed">
            <views:ChannelBoardView
                x:Name="AllChannelBoard"
                Visibility="Collapsed"
                ImagePreviewRequested="ChannelCardView_ImagePreviewRequested"
                ShowImageRequested="ChannelCardView_ShowImageRequested" />

            <views:ChannelBoardView
                x:Name="JoinedChannelBoard"
                Visibility="Visible"
                ImagePreviewRequested="ChannelCardView_ImagePreviewRequested"
                ShowImageRequested="ChannelCardView_ShowImageRequested" />

            <views:ChannelBoardView
                x:Name="NotJoinedChannelBoard"
                Visibility="Collapsed"
                ImagePreviewRequested="ChannelCardView_ImagePreviewRequested"
                ShowImageRequested="ChannelCardView_ShowImageRequested" />

            <views:ChannelBoardView
                x:Name="CustomChannelBoard"
                Visibility="Collapsed"
                ImagePreviewRequested="ChannelCardView_ImagePreviewRequested"
                ShowImageRequested="ChannelCardView_ShowImageRequested" />

            <views:StatusPanelView x:Name="StatusPanel" />

            <views:MainControllerView
                x:Name="MainController"
                GearIconClick="MainController_GearIconClick"
                MessageIconClick="MainController_MessageIconClick"
                MessageCommentRequested="MainController_MessageCommentRequested"
                PlusIconClick="MainController_PlusIconClick"
                CircleIcon1Click="MainController_CircleIcon1Click"
                CircleIcon2Click="MainController_CircleIcon2Click"
                CustomChannelClick="MainController_CustomChannelClick"
                AddChannelsRequested="MainController_AddChannelsRequested"
                UpdateCustomBoardRequested="MainController_UpdateCustomBoardRequested"
                CopyLogRequested="LogPopupView_CopyLogRequested"
                RefreshRequested="LogPopupView_RefreshRequested"
                UpdateTokenRequested="UserPopupView_UpdateTokenRequested"
                LogoutRequested="UserPopupView_LogoutRequested"
                AutoRefreshToggleRequested="UserPopupView_AutoRefreshToggleRequested" />
        </Grid>

        <Grid
            x:Name="ImagePreviewOverlay"
            Visibility="Collapsed"
            Background="#B3000000"
            IsTabStop="True"
            KeyDown="ImagePreviewOverlay_KeyDown">
            <Grid
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Padding="32">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Button
                    x:Name="ImagePreviewCloseButton"
                    Grid.Row="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Content="閉じる"
                    Click="ImagePreviewCloseButton_Click"
                    Padding="16,8"
                    Margin="0,0,0,16" />

                <ScrollViewer
                    Grid.Row="1"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"
                    ZoomMode="Enabled"
                    MinZoomFactor="1"
                    MaxZoomFactor="5">
                    <Border
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="Transparent"
                        Padding="16">
                        <Image
                            x:Name="ImagePreviewImage"
                            Stretch="Uniform"
                            MaxWidth="1600"
                            MaxHeight="1000" />
                    </Border>
                </ScrollViewer>
            </Grid>
        </Grid>

        <Grid
            x:Name="StartupSplashOverlay"
            Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="20">
                <Border
                    Width="220"
                    Height="220"
                    CornerRadius="40"
                    Background="Transparent">
                    <Image
                        x:Name="StartupSplashImage"
                        Stretch="Uniform" />
                </Border>

                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="42"
                    FontWeight="Bold"
                    Text="SlackSitter" />

                <ProgressRing
                    IsActive="True"
                    Width="48"
                    Height="48"
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
