<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SlackSitter.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SlackSitter"
    xmlns:converters="using:SlackSitter.Converters"
    xmlns:views="using:SlackSitter.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SlackSitter">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <converters:TimestampToDateTimeConverter x:Key="TimestampToDateTimeConverter" />
            <converters:BooleanToHeaderBrushConverter x:Key="BooleanToHeaderBrushConverter" />
            <converters:SlackMessageTextConverter x:Key="SlackMessageTextConverter" />
        </Grid.Resources>
        <views:AuthenticationView
            x:Name="AuthenticationPanel"
            Visibility="Collapsed"
            AuthenticateRequested="AuthenticationView_AuthenticateRequested" />

        <Grid x:Name="MainPanel" Visibility="Collapsed">
            <!-- チャンネル表示エリア -->
            <ScrollViewer 
                x:Name="ChannelScrollViewer"
                HorizontalScrollBarVisibility="Auto" 
                VerticalScrollBarVisibility="Disabled"
                Padding="20"
                SizeChanged="ChannelScrollViewer_SizeChanged">
                <ItemsControl x:Name="TimesChannelsItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="16" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <views:ChannelCardView
                                Channel="{Binding}"
                                MessageRichTextBlockLoadedRequested="ChannelCardView_MessageRichTextBlockLoadedRequested"
                                MessageAvatarBorderLoadedRequested="ChannelCardView_MessageAvatarBorderLoadedRequested"
                                ReactionBorderLoadedRequested="ChannelCardView_ReactionBorderLoadedRequested"
                                ShowImageRequested="ChannelCardView_ShowImageRequested" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ステータスメッセージエリア（初期表示用） -->
            <StackPanel 
                x:Name="StatusPanel"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Spacing="16"
                MaxWidth="700"
                Visibility="Visible">
                <TextBlock 
                    x:Name="StatusText" 
                    Text="" 
                    FontSize="14" 
                    HorizontalAlignment="Center" 
                    TextWrapping="Wrap" 
                    TextAlignment="Center"
                    Foreground="Green" />

                <TextBlock 
                    x:Name="ErrorText" 
                    Text="" 
                    FontSize="14" 
                    HorizontalAlignment="Center" 
                    TextWrapping="Wrap" 
                    TextAlignment="Center"
                    Foreground="Red" 
                    Visibility="Collapsed" />

                <Border 
                    x:Name="RequiredScopesPanel"
                    Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}" 
                    BorderThickness="2" 
                    CornerRadius="8" 
                    Padding="16" 
                    Visibility="Collapsed">
                    <StackPanel Spacing="8">
                        <TextBlock 
                            Text="⚠️ 必要な権限（スコープ）" 
                            FontWeight="Bold" 
                            FontSize="16" />
                        <TextBlock 
                            Text="Access Token に以下の権限が必要です：" 
                            TextWrapping="Wrap" />
                        <TextBlock 
                            Text="• channels:read - パブリックチャンネルの読み取り" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• channels:history - パブリックチャンネルのメッセージ履歴" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• groups:read - プライベートチャンネルの読み取り" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• groups:history - プライベートチャンネルのメッセージ履歴" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• mpim:read - グループDMの読み取り" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• mpim:history - グループDMのメッセージ履歴" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• im:read - DMの読み取り" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• im:history - DMのメッセージ履歴" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• users:read - ユーザー情報の読み取り" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• chat:write - メッセージの送信" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• emoji:read - カスタム絵文字の読み取り" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="" />
                        <TextBlock 
                            Text="Slack App の設定で OAuth Scopes にこれらの権限を追加し、新しいトークンを再発行してください。" 
                            TextWrapping="Wrap" 
                            Foreground="Gray" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <views:UserPopupView
                x:Name="UserPopupBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="59,0,0,75"
                Visibility="Collapsed"
                UpdateTokenRequested="UserPopupView_UpdateTokenRequested"
                LogoutRequested="UserPopupView_LogoutRequested"
                AutoRefreshToggleRequested="UserPopupView_AutoRefreshToggleRequested" />

            <views:LogPopupView
                x:Name="LogPopupBorder"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="-59,0,0,75"
                Visibility="Collapsed"
                CopyLogRequested="LogPopupView_CopyLogRequested"
                RefreshRequested="LogPopupView_RefreshRequested" />

            <views:CircleActionButtonView
                x:Name="LoadingIndicatorButton"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="-118,0,0,20"
                CenterGlyph="&#xE895;"
                ContentForeground="Gray"
                Click="LoadingIndicatorButton_Click"
                Visibility="Collapsed" />

            <views:CircleActionButtonView
                x:Name="GearIconButton"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,20"
                InnerBorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                CenterGlyph="&#xE713;"
                Click="GearIconButton_Click"
                Visibility="Collapsed" />

            <views:CircleActionButtonView
                x:Name="UserAvatarButton"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="118,0,0,20"
                InnerBorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                Click="UserAvatarButton_Click"
                Visibility="Collapsed" />

            <views:CircleActionButtonView
                x:Name="PlusIconButton"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="236,0,0,20"
                InnerBorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                CenterGlyph="&#xE710;"
                Click="PlusIconButton_Click"
                Visibility="Collapsed" />

            <views:CircleActionButtonView
                x:Name="CircleIcon1Button"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="354,0,0,20"
                InnerBorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                CenterText="①"
                Click="CircleIcon1Button_Click"
                Visibility="Collapsed" />

            <views:CircleActionButtonView
                x:Name="CircleIcon2Button"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="472,0,0,20"
                InnerBorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                CenterText="②"
                Click="CircleIcon2Button_Click"
                Visibility="Collapsed" />
        </Grid>
    </Grid>
</Window>
