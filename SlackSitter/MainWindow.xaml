<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SlackSitter.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SlackSitter"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SlackSitter">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid x:Name="AuthenticationPanel" Visibility="Visible">
            <StackPanel 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Width="500" 
                Spacing="12">
                <TextBlock 
                    Text="Slack 認証" 
                    FontSize="24" 
                    FontWeight="Bold" 
                    HorizontalAlignment="Center" 
                    Margin="0,0,0,12" />

                <Border 
                    Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="12"
                    Margin="0,0,0,12">
                    <StackPanel Spacing="8">
                        <TextBlock 
                            Text="💡 トークンの生成方法" 
                            FontWeight="SemiBold" 
                            FontSize="14" />
                        <TextBlock 
                            Text="1. Slack App の設定ページを開く" 
                            TextWrapping="Wrap" 
                            FontSize="12" />
                        <TextBlock 
                            Text="2. OAuth &amp; Permissions → Scopes → User Token Scopes に以下を追加:" 
                            TextWrapping="Wrap" 
                            FontSize="12" />
                        <TextBlock 
                            Text="   channels:read, groups:read, mpim:read, im:read, users:read, chat:write" 
                            TextWrapping="Wrap" 
                            FontSize="11" 
                            FontFamily="Consolas"
                            Foreground="Gray" />
                        <TextBlock 
                            Text="3. 再インストール後、User OAuth Token をコピー" 
                            TextWrapping="Wrap" 
                            FontSize="12" />
                    </StackPanel>
                </Border>

                <TextBlock 
                    Text="User OAuth Token" 
                    FontWeight="SemiBold" 
                    Margin="0,8,0,4" />
                <PasswordBox 
                    x:Name="AccessTokenPasswordBox" 
                    PlaceholderText="xoxp-..." 
                    Width="500" />

                <Button
                    x:Name="AuthenticateButton" 
                    Content="認証" 
                    Click="AuthenticateButton_Click" 
                    HorizontalAlignment="Center" 
                    Style="{StaticResource AccentButtonStyle}" 
                    Margin="0,12,0,0" />

                <TextBlock 
                    x:Name="AuthenticationStatusText" 
                    Text="" 
                    Foreground="Red" 
                    HorizontalAlignment="Center" 
                    TextWrapping="Wrap" 
                    Width="500" 
                    TextAlignment="Center" />
            </StackPanel>
        </Grid>

        <Grid x:Name="MainPanel" Visibility="Collapsed">
            <StackPanel 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Spacing="16"
                MaxWidth="700">
                <TextBlock 
                    Text="認証成功！" 
                    FontSize="24" 
                    FontWeight="Bold" 
                    HorizontalAlignment="Center" />

                <TextBlock 
                    x:Name="StatusText" 
                    Text="" 
                    FontSize="14" 
                    HorizontalAlignment="Center" 
                    TextWrapping="Wrap" 
                    TextAlignment="Center"
                    Foreground="Green" />

                <TextBlock 
                    x:Name="ErrorText" 
                    Text="" 
                    FontSize="14" 
                    HorizontalAlignment="Center" 
                    TextWrapping="Wrap" 
                    TextAlignment="Center"
                    Foreground="Red" 
                    Visibility="Collapsed" />

                <Border 
                    x:Name="RequiredScopesPanel"
                    Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}" 
                    BorderThickness="2" 
                    CornerRadius="8" 
                    Padding="16" 
                    Visibility="Collapsed">
                    <StackPanel Spacing="8">
                        <TextBlock 
                            Text="⚠️ 必要な権限（スコープ）" 
                            FontWeight="Bold" 
                            FontSize="16" />
                        <TextBlock 
                            Text="Access Token に以下の権限が必要です：" 
                            TextWrapping="Wrap" />
                        <TextBlock 
                            Text="• channels:read - パブリックチャンネルの読み取り" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• groups:read - プライベートチャンネルの読み取り" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• mpim:read - グループDMの読み取り" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• im:read - DMの読み取り" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• users:read - ユーザー情報の読み取り" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• chat:write - メッセージの送信" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="" />
                        <TextBlock 
                            Text="Slack App の設定で OAuth Scopes にこれらの権限を追加し、新しいトークンを再発行してください。" 
                            TextWrapping="Wrap" 
                            Foreground="Gray" />
                    </StackPanel>
                </Border>

                <TextBlock 
                    x:Name="EnvPathText" 
                    Text="" 
                    FontSize="12" 
                    HorizontalAlignment="Center" 
                    TextWrapping="Wrap" 
                    Foreground="Gray" />

                <Button 
                    x:Name="LogoutButton" 
                    Content="ログアウト" 
                    Click="LogoutButton_Click" 
                    HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Grid>
</Window>
