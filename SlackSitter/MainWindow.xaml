<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="SlackSitter.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:SlackSitter"
    xmlns:converters="using:SlackSitter.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="SlackSitter">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.Resources>
            <converters:TimestampToDateTimeConverter x:Key="TimestampToDateTimeConverter" />
            <converters:BooleanToHeaderBrushConverter x:Key="BooleanToHeaderBrushConverter" />
            <converters:SlackMessageTextConverter x:Key="SlackMessageTextConverter" />
        </Grid.Resources>
        <Grid x:Name="AuthenticationPanel" Visibility="Collapsed">
            <StackPanel 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Width="500" 
                Spacing="12">
                <TextBlock 
                    Text="Slack 認証" 
                    FontSize="24" 
                    FontWeight="Bold" 
                    HorizontalAlignment="Center" 
                    Margin="0,0,0,12" />

                <Border 
                    Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="12"
                    Margin="0,0,0,12">
                    <StackPanel Spacing="8">
                        <TextBlock 
                            Text="💡 トークンの生成方法" 
                            FontWeight="SemiBold" 
                            FontSize="14" />
                        <TextBlock 
                            Text="1. Slack App の設定ページを開く" 
                            TextWrapping="Wrap" 
                            FontSize="12" />
                        <TextBlock 
                            Text="2. OAuth &amp; Permissions → Scopes → User Token Scopes に以下を追加:" 
                            TextWrapping="Wrap" 
                            FontSize="12" />
                        <TextBlock 
                            Text="   channels:read, channels:history, groups:read, groups:history," 
                            TextWrapping="Wrap" 
                            FontSize="11" 
                            FontFamily="Consolas"
                            Foreground="Gray" />
                        <TextBlock 
                            Text="   mpim:read, mpim:history, im:read, im:history, users:read, chat:write, emoji:read" 
                            TextWrapping="Wrap" 
                            FontSize="11" 
                            FontFamily="Consolas"
                            Foreground="Gray" />
                        <TextBlock 
                            Text="3. 再インストール後、User OAuth Token をコピー" 
                            TextWrapping="Wrap" 
                            FontSize="12" />
                    </StackPanel>
                </Border>

                <TextBlock 
                    Text="User OAuth Token" 
                    FontWeight="SemiBold" 
                    Margin="0,8,0,4" />
                <PasswordBox 
                    x:Name="AccessTokenPasswordBox" 
                    PlaceholderText="xoxp-..." 
                    Width="500" />

                <Button
                    x:Name="AuthenticateButton" 
                    Content="認証" 
                    Click="AuthenticateButton_Click" 
                    HorizontalAlignment="Center" 
                    Style="{StaticResource AccentButtonStyle}" 
                    Margin="0,12,0,0" />

                <TextBlock 
                    x:Name="AuthenticationStatusText" 
                    Text="" 
                    Foreground="Red" 
                    HorizontalAlignment="Center" 
                    TextWrapping="Wrap" 
                    Width="500" 
                    TextAlignment="Center" />
            </StackPanel>
        </Grid>

        <Grid x:Name="MainPanel" Visibility="Collapsed">
            <!-- チャンネル表示エリア -->
            <ScrollViewer 
                x:Name="ChannelScrollViewer"
                HorizontalScrollBarVisibility="Auto" 
                VerticalScrollBarVisibility="Disabled"
                Padding="20"
                SizeChanged="ChannelScrollViewer_SizeChanged">
                <ItemsControl x:Name="TimesChannelsItemsControl">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="16" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border 
                                Background="{ThemeResource LayerFillColorDefaultBrush}" 
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                                BorderThickness="1" 
                                CornerRadius="8" 
                                Width="300"
                                x:Name="ChannelBorder">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- チャンネル名ヘッダー -->
                                    <Border 
                                        Grid.Row="0"
                                        Background="{Binding IsMember, Converter={StaticResource BooleanToHeaderBrushConverter}}" 
                                        CornerRadius="8,8,0,0" 
                                        Padding="16,12">
                                        <TextBlock 
                                            Text="{Binding Name}" 
                                            FontWeight="Bold" 
                                            FontSize="16" 
                                            Foreground="White" />
                                    </Border>

                                    <!-- コンテンツエリア -->
                                    <ScrollViewer 
                                        Grid.Row="1" 
                                        Padding="12"
                                        VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding Messages}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,8,0,4">
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                        </Grid.RowDefinitions>
                                                        <TextBlock 
                                                            Grid.Row="0"
                                                            Text="{Binding Ts, Converter={StaticResource TimestampToDateTimeConverter}}" 
                                                            FontSize="10"
                                                            Foreground="Gray"
                                                            HorizontalAlignment="Right"
                                                            Margin="0,0,8,2" />
                                                        <Border 
                                                            Grid.Row="1"
                                                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="4"
                                                            Padding="8">
                                                            <RichTextBlock
                                                                Tag="{Binding Text}"
                                                                Loaded="MessageRichTextBlock_Loaded"
                                                                TextWrapping="Wrap"
                                                                FontSize="18" />
                                                        </Border>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ステータスメッセージエリア（初期表示用） -->
            <StackPanel 
                x:Name="StatusPanel"
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Spacing="16"
                MaxWidth="700"
                Visibility="Visible">
                <TextBlock 
                    x:Name="StatusText" 
                    Text="" 
                    FontSize="14" 
                    HorizontalAlignment="Center" 
                    TextWrapping="Wrap" 
                    TextAlignment="Center"
                    Foreground="Green" />

                <TextBlock 
                    x:Name="ErrorText" 
                    Text="" 
                    FontSize="14" 
                    HorizontalAlignment="Center" 
                    TextWrapping="Wrap" 
                    TextAlignment="Center"
                    Foreground="Red" 
                    Visibility="Collapsed" />

                <Border 
                    x:Name="RequiredScopesPanel"
                    Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}" 
                    BorderThickness="2" 
                    CornerRadius="8" 
                    Padding="16" 
                    Visibility="Collapsed">
                    <StackPanel Spacing="8">
                        <TextBlock 
                            Text="⚠️ 必要な権限（スコープ）" 
                            FontWeight="Bold" 
                            FontSize="16" />
                        <TextBlock 
                            Text="Access Token に以下の権限が必要です：" 
                            TextWrapping="Wrap" />
                        <TextBlock 
                            Text="• channels:read - パブリックチャンネルの読み取り" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• channels:history - パブリックチャンネルのメッセージ履歴" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• groups:read - プライベートチャンネルの読み取り" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• groups:history - プライベートチャンネルのメッセージ履歴" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• mpim:read - グループDMの読み取り" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• mpim:history - グループDMのメッセージ履歴" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• im:read - DMの読み取り" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• im:history - DMのメッセージ履歴" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• users:read - ユーザー情報の読み取り" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• chat:write - メッセージの送信" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="• emoji:read - カスタム絵文字の読み取り" 
                            FontFamily="Consolas" />
                        <TextBlock 
                            Text="" />
                        <TextBlock 
                            Text="Slack App の設定で OAuth Scopes にこれらの権限を追加し、新しいトークンを再発行してください。" 
                            TextWrapping="Wrap" 
                            Foreground="Gray" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- 吹き出しポップアップ -->
            <Grid 
                x:Name="UserPopupBorder"
                HorizontalAlignment="Center" 
                VerticalAlignment="Bottom" 
                Margin="59,0,0,75"
                Visibility="Collapsed">

                <!-- メインの吹き出しボックス -->
                <Border 
                    Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="16"
                    MinWidth="250"
                    Margin="0,0,0,15">
                    <StackPanel Spacing="12">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border 
                                Width="40" 
                                Height="40" 
                                CornerRadius="20" 
                                BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                                BorderThickness="2">
                                <Border.Background>
                                    <ImageBrush x:Name="PopupAvatarBrush" Stretch="UniformToFill" />
                                </Border.Background>
                            </Border>
                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                <TextBlock 
                                    x:Name="PopupUserNameText" 
                                    Text="" 
                                    FontWeight="SemiBold" 
                                    FontSize="14" />
                                <TextBlock 
                                    x:Name="PopupUserIdText" 
                                    Text="" 
                                    FontSize="12" 
                                    Foreground="Gray" />
                            </StackPanel>
                        </StackPanel>

                        <Border 
                            Height="1" 
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <!-- トークン変更フォーム -->
                        <StackPanel Spacing="8">
                            <TextBlock 
                                Text="トークンの変更" 
                                FontWeight="SemiBold" 
                                FontSize="13" />
                            <PasswordBox 
                                x:Name="PopupAccessTokenPasswordBox" 
                                PlaceholderText="新しいトークン (xoxp-...)" 
                                Width="Auto" />
                            <Button 
                                x:Name="PopupUpdateTokenButton"
                                Content="トークンを更新" 
                                Click="PopupUpdateTokenButton_Click" 
                                HorizontalAlignment="Stretch" 
                                Style="{StaticResource AccentButtonStyle}" />
                            <TextBlock 
                                x:Name="PopupTokenStatusText" 
                                Text="" 
                                FontSize="11" 
                                HorizontalAlignment="Center" 
                                TextWrapping="Wrap" 
                                TextAlignment="Center"
                                Visibility="Collapsed" />
                        </StackPanel>

                        <Border 
                            Height="1" 
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <!-- envファイルパス表示 -->
                        <TextBlock 
                            x:Name="EnvPathText" 
                            Text="" 
                            FontSize="11" 
                            TextWrapping="Wrap" 
                            Foreground="Gray" 
                            TextAlignment="Center" />

                        <Button 
                            Content="ログアウト" 
                            Click="PopupLogoutButton_Click" 
                            HorizontalAlignment="Stretch" />
                    </StackPanel>
                </Border>

                <!-- 吹き出しのポインター（三角形） -->
                <Polygon 
                    Points="0,0 10,15 20,0" 
                    Fill="{ThemeResource LayerFillColorDefaultBrush}" 
                    Stroke="{ThemeResource CardStrokeColorDefaultBrush}"
                    StrokeThickness="1"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Bottom" 
                    Margin="0,0,0,0" />
            </Grid>

            <!-- ログ表示ポップアップ -->
            <Grid 
                x:Name="LogPopupBorder"
                HorizontalAlignment="Center" 
                VerticalAlignment="Bottom" 
                Margin="-59,0,0,75"
                Visibility="Collapsed">

                <!-- メインの吹き出しボックス -->
                <Border 
                    Background="{ThemeResource LayerFillColorDefaultBrush}" 
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" 
                    BorderThickness="1" 
                    CornerRadius="8" 
                    Padding="16"
                    MinWidth="400"
                    MaxWidth="600"
                    Margin="0,0,0,15">
                    <StackPanel Spacing="12">
                        <TextBlock 
                            Text="データ取得ログ" 
                            FontWeight="SemiBold" 
                            FontSize="14" />

                        <Border 
                            Height="1" 
                            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

                        <!-- ログ表示エリア -->
                        <ScrollViewer 
                            MaxHeight="300"
                            VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="LogItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock 
                                            Text="{Binding}" 
                                            FontSize="11" 
                                            FontFamily="Consolas"
                                            TextWrapping="Wrap"
                                            Margin="0,2" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- 吹き出しのポインター（三角形） -->
                <Polygon 
                    Points="0,0 10,15 20,0" 
                    Fill="{ThemeResource LayerFillColorDefaultBrush}" 
                    Stroke="{ThemeResource CardStrokeColorDefaultBrush}"
                    StrokeThickness="1"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Bottom" 
                    Margin="0,0,0,0" />
            </Grid>

            <!-- データ取得状況インジケーター -->
            <Button 
                x:Name="LoadingIndicatorButton"
                Width="48" 
                Height="48" 
                Padding="0"
                HorizontalAlignment="Center" 
                VerticalAlignment="Bottom" 
                Margin="-59,0,0,20"
                Background="Transparent"
                BorderThickness="0"
                CornerRadius="24"
                Click="LoadingIndicatorButton_Click"
                Visibility="Collapsed">
                <Border 
                    Width="48" 
                    Height="48" 
                    CornerRadius="24" 
                    x:Name="LoadingIndicator"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderThickness="2">
                    <FontIcon 
                        x:Name="LoadingIcon"
                        Glyph="&#xE895;" 
                        FontSize="24" 
                        Foreground="Gray" />
                </Border>
            </Button>

            <!-- ユーザーアイコンボタン -->
            <Button 
                x:Name="UserAvatarButton"
                Width="48" 
                Height="48" 
                Padding="0"
                HorizontalAlignment="Center" 
                VerticalAlignment="Bottom" 
                Margin="59,0,0,20"
                Background="Transparent"
                BorderThickness="0"
                CornerRadius="24"
                Click="UserAvatarButton_Click"
                Visibility="Collapsed">
                <Border 
                    Width="48" 
                    Height="48" 
                    CornerRadius="24" 
                    BorderBrush="{ThemeResource AccentFillColorDefaultBrush}"
                    BorderThickness="2">
                    <Border.Background>
                        <ImageBrush x:Name="UserAvatarBrush" Stretch="UniformToFill" />
                    </Border.Background>
                </Border>
            </Button>
        </Grid>
    </Grid>
</Window>
